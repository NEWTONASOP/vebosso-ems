{
  "expo": {
    "name": "VEBOSSO EMS",
    "slug": "vebosso-ems",
    "version": "1.2.2",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "vebossoems",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.vebosso.ems"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png",
        "backgroundColor": "#0A0F1E"
      },
      "package": "com.vebosso.ems",
      "googleServicesFile": "./google-services.json",
      "predictiveBackGestureEnabled": false,
      "allowBackup": false,
      "minSdkVersion": 29
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "headers": {
            "Cross-Origin-Embedder-Policy": "credentialless",
            "Cross-Origin-Opener-Policy": "same-origin"
          }
        }
      ],
      "expo-font",
      "expo-secure-store",
      [
        "expo-sqlite",
        {
          "enableFTS": false,
          "useSQLCipher": false
        }
      ],
      [
        "expo-notifications",
        {
          "color": "#2563EB"
        }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#FFFFFF",
          "android": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 120,
            "resizeMode": "contain"
          },
          "ios": {
            "image": "./assets/images/splash-icon.png",
            "resizeMode": "contain"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "4ac738d0-e4b2-4814-8eb5-2389074f5c4a"
      }
    },
    "owner": "newtane",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/4ac738d0-e4b2-4814-8eb5-2389074f5c4a"
    }
  }
}